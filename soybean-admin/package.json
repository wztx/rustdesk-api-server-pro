{
  "name": "soybean-admin",
  "type": "module",
  "version": "1.3.4",
  "description": "A fresh and elegant admin template, based on Vue3、Vite3、TypeScript、NaiveUI and UnoCSS. 一个基于Vue3、Vite3、TypeScript、NaiveUI and UnoCSS的清新优雅的中后台模版。",
  "author": {
    "name": "Soybean",
    "email": "soybeanjs@outlook.com",
    "url": "https://github.com/soybeanjs"
  },
  "license": "MIT",
  "homepage": "https://github.com/soybeanjs/soybean-admin",
  "repository": {
    "url": "https://github.com/soybeanjs/soybean-admin.git"
  },
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-admin/issues"
  },
  "keywords": [
    "Vue3 admin ",
    "vue-admin-template",
    "Vite5",
    "TypeScript",
    "naive-ui",
    "naive-ui-admin",
    "ant-design-vue v4",
    "UnoCSS"
  ],
  "engines": {
    "node": ">=18.12.0",
    "pnpm": ">=8.7.0"
  },
  "scripts": {
    "build": "vite build --mode prod",
    "build:test": "vite build --mode test",
    "cleanup": "sa cleanup",
    "commit": "sa git-commit",
    "commit:zh": "sa git-commit -l=zh-cn",
    "dev": "vite --mode test",
    "dev:prod": "vite --mode prod",
    "gen-route": "sa gen-route",
    "i18n:check:strict": "tsx scripts/i18n-quality-check.ts --strict",
    "i18n:check:json": "tsx scripts/i18n-quality-check.ts --json",
    "i18n:check:ru": "tsx scripts/i18n-quality-check.ts --locale=ru-RU",
    "i18n:check": "tsx scripts/i18n-quality-check.ts",
    "i18n:compare": "tsx scripts/i18n-quality-compare.ts",
    "i18n:check:report": "pnpm i18n:check && pnpm i18n:report",
    "i18n:report": "tsx scripts/i18n-coverage-report.ts",
    "i18n:todo": "tsx scripts/i18n-fallback-todo.ts",
    "i18n:todo:ru": "tsx scripts/i18n-fallback-todo.ts --locale=ru-RU --top=120",
    "i18n:summary": "tsx scripts/i18n-quality-summary.ts",
    "i18n:sanitize": "tsx scripts/i18n-sanitize-placeholders.ts",
    "i18n:sanitize:dry": "tsx scripts/i18n-sanitize-placeholders.ts --dry-run",
    "i18n:sanitize:json": "tsx scripts/i18n-sanitize-placeholders.ts --dry-run --json",
    "i18n:sanitize:guard": "tsx scripts/i18n-sanitize-placeholders.ts --dry-run --fail-on-detect",
    "i18n:sanitize:ru": "tsx scripts/i18n-sanitize-placeholders.ts --locale=ru-RU",
    "ci:i18n": "pnpm i18n:check && pnpm i18n:report && pnpm i18n:todo && pnpm i18n:summary && pnpm i18n:compare",
    "ci:quality": "pnpm i18n:sanitize:guard && pnpm i18n:check && pnpm typecheck",
    "ci:frontend": "pnpm i18n:sanitize:guard && pnpm i18n:check && pnpm typecheck && pnpm build",
    "lint": "eslint . --fix",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "release": "sa release",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "update-pkg": "sa update-pkg"
  },
  "dependencies": {
    "@better-scroll/core": "2.5.1",
    "@iconify/vue": "4.1.2",
    "@sa/axios": "workspace:*",
    "@sa/color": "workspace:*",
    "@sa/hooks": "workspace:*",
    "@sa/materials": "workspace:*",
    "@sa/utils": "workspace:*",
    "@vueuse/core": "10.11.1",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "clipboard": "2.0.11",
    "dayjs": "1.11.12",
    "echarts": "5.5.1",
    "naive-ui": "2.39.0",
    "nprogress": "0.2.0",
    "pinia": "2.2.1",
    "qrcode": "^1.5.4",
    "tailwind-merge": "2.5.2",
    "vue": "3.4.37",
    "vue-draggable-plus": "0.5.3",
    "vue-i18n": "9.13.1",
    "vue-router": "4.4.3"
  },
  "devDependencies": {
    "@elegant-router/vue": "0.3.8",
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/fluent": "^1.2.39",
    "@iconify-json/gridicons": "^1.2.4",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/uil": "^1.2.3",
    "@iconify/json": "2.2.237",
    "@iconify/utils": "2.1.30",
    "@sa/scripts": "workspace:*",
    "@sa/uno-preset": "workspace:*",
    "@soybeanjs/eslint-config": "1.4.0",
    "@types/node": "22.2.0",
    "@types/nprogress": "0.2.3",
    "@types/qrcode": "^1.5.6",
    "@unocss/core": "0.62.1",
    "@unocss/eslint-config": "0.62.1",
    "@unocss/preset-icons": "0.62.1",
    "@unocss/preset-uno": "0.62.1",
    "@unocss/transformer-directives": "0.62.1",
    "@unocss/transformer-variant-group": "0.62.1",
    "@unocss/vite": "66.7.4",
    "@vitejs/plugin-vue": "5.1.2",
    "@vitejs/plugin-vue-jsx": "4.0.0",
    "eslint": "9.9.0",
    "eslint-plugin-vue": "9.27.0",
    "json5": "2.2.3",
    "lint-staged": "15.2.9",
    "sass": "1.77.8",
    "simple-git-hooks": "2.11.1",
    "tsx": "4.17.0",
    "typescript": "5.5.4",
    "unplugin-icons": "0.19.2",
    "unplugin-vue-components": "0.27.4",
    "vite": "5.4.0",
    "vite-plugin-progress": "0.0.7",
    "vite-plugin-svg-icons": "2.0.1",
    "vite-plugin-vue-devtools": "7.3.8",
    "vue-eslint-parser": "9.4.3",
    "vue-tsc": "3.3.5"
  },
  "simple-git-hooks": {},
  "lint-staged": {
    "*": "eslint --fix"
  },
  "website": "https://admin.soybeanjs.cn"
}
